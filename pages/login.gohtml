{{define "page"}}{{template "base" .}}{{end}}

{{define "head"}}
<link rel="stylesheet" href="/css/login.css">
{{end}}

{{define "content"}}
<div class="login-container">
    <div class="back-link">
        <a href="/">← Back to Home</a>
    </div>
    
    <div class="login-header">
        <h1>🌊 Login</h1>
        <p>Welcome back to TauchoPortal</p>
    </div>
    {{template "login" .}}
</div>
{{end}}
