{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cloud Run: Run/Debug Locally",
            "type": "cloudcode.cloudrun",
            "request": "launch",
            "build": {
                "buildpacks": {
                    "path": "go.mod",
                    "builder": "gcr.io/buildpacks/builder:v1"
                }
            },
            "image": "tauchoportal",
            "service": {
                "name": "tauchoportal",
                "containerPort": 8080,
                "resources": {
                    "limits": {
                        "memory": "256Mi"
                    }
                }
            },
            "target": {
                "minikube": {}
            },
            "watch": true
        },
        {
            "name": "Debug Taucho Potal",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd",
            "cwd": "${workspaceFolder}",
            "env": {
                "PORT": "8080",
                "API_URL": "http://localhost:8081"
            },
            "args": [],
            "showLog": true,
            "trace": "verbose"
        }
    ]
}
